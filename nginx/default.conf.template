server {
  listen 80;
  location = /ping {
    add_header Content-Type text/plain;
    return 200 'pong';
  }
  location /html/ {
    alias /var/www/html/;
    index index.html;
  }
  location / {
    proxy_set_header Content-Type application/json;
    proxy_pass http://${APP_HOST}:${APP_PORT};
  }
}
