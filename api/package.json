{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node -r tsconfig-paths/register -r ts-node/register dist/app.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec ts-node -r tsconfig-paths/register src/app.ts",
    "lint": "eslint --fix",
    "lint:ci": "eslint",
    "format": "prettier --write --list-different 'src/**/*.ts' '*.(config.mjs|json)'",
    "format:ci": "prettier --list-different 'src/**/*.ts' '*.(config.mjs|json)'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "7.2.0",
    "axios": "1.13.6",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-winston": "4.2.0",
    "http-errors": "2.0.1",
    "winston": "3.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.0.3",
    "@typescript-eslint/eslint-plugin": "8.50.1",
    "@typescript-eslint/parser": "8.50.1",
    "eslint": "9.39.2",
    "nodemon": "3.1.11",
    "prettier": "3.7.4",
    "prisma": "7.2.0",
    "ts-node": "10.9.2",
    "tsc": "2.0.4",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1"
  }
}
